{
  "expo": {
    "name": "Lastr'",
    "slug": "lastr-app",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo_nobg.png",
    "scheme": "lastr",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.theawesomeco.lastr",
      "usesAppleSignIn": true,
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo_nobg.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.lastr.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo_nobg.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A0F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
